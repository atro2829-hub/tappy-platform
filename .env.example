APP_NAME=Tappy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============= DATABASE (Supabase PostgreSQL) =============
DB_CONNECTION=pgsql
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your_password
DB_SSLMODE=prefer

# ============= SUPABASE =============
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=supabase
QUEUE_CONNECTION=database

CACHE_STORE=database

PROVIDER_DRIVER=fake
PROVIDER_FALLBACK_DRIVER=

RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_SANDBOX=true
RELOADLY_WEBHOOK_SECRET=

DINGCONNECT_API_KEY=
DINGCONNECT_SANDBOX=true

DTONE_API_KEY=
DTONE_API_SECRET=
DTONE_SANDBOX=true

GIFTCARD_DRIVER=fake
GIFTCARD_FALLBACK_DRIVER=

TREMENDOUS_API_KEY=
TREMENDOUS_SANDBOX=true

TILLO_API_KEY=
TILLO_SECRET=
TILLO_SECTOR=marketplace
TILLO_SANDBOX=true

GIFTBIT_API_KEY=
GIFTBIT_SANDBOX=true

TANGO_PLATFORM_NAME=
TANGO_PLATFORM_KEY=
TANGO_ACCOUNT_IDENTIFIER=
TANGO_CUSTOMER_IDENTIFIER=
TANGO_SANDBOX=true

VITE_APP_NAME="${APP_NAME}"
VITE_SUPABASE_URL="${SUPABASE_URL}"
VITE_SUPABASE_KEY="${SUPABASE_KEY}"

STRIPE_KEY=
STRIPE_SECRET=

PAYMENT_DRIVER=stripe

# ============= CURRENCY =============
BASE_CURRENCY=YER
SUPPORTED_CURRENCIES=YER,SAR,USD
